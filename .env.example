# Copy to .env and adjust as needed.
PORT=4000

# Allowed browser origin(s) for CORS. Single value, or a comma-separated list to
# allow several (e.g. local dev + your deployed frontend):
#   CLIENT_ORIGIN=http://localhost:5173,https://your-app.vercel.app
CLIENT_ORIGIN=http://localhost:5173

# --- Database ---
# Point at a real MongoDB for persistence (local install or Atlas):
#   MONGO_URI=mongodb://127.0.0.1:27017/colorgame
#   MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/colorgame
MONGO_URI=

# Zero-setup dev with no MongoDB installed (data is EPHEMERAL).
# Used only when MONGO_URI is empty. Set to 1 to enable.
USE_MEMORY_DB=
